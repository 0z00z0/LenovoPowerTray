<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="LenovoTray.UI.DashboardWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <!-- No fixed Width: the grid fills the window, which is sized in code per monitor DPI.
         The window height is measured from this grid (PlaceWindow), so rows can appear/disappear
         without any hard-coded height constants. -->
    <Grid x:Name="RootGrid" Padding="20,16,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: Header -->
            <RowDefinition Height="Auto"/>  <!-- 1: Gauge + stats -->
            <RowDefinition Height="Auto"/>  <!-- 2: History sparkline -->
            <RowDefinition Height="Auto"/>  <!-- 3: Separator -->
            <RowDefinition Height="Auto"/>  <!-- 4: Status badges -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Lenovo Power"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                   Margin="0,0,0,14"/>

        <!-- Battery gauge section: gauge left, stats right filling remaining width -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Circular arc gauge -->
            <Grid Grid.Column="0" Width="100" Height="100" Margin="0,0,16,0">
                <!-- Background arc (track) -->
                <Canvas Width="100" Height="100">
                    <Path x:Name="GaugeTrack"
                          Stroke="{ThemeResource ControlStrokeColorDefaultBrush}"
                          StrokeThickness="8"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Canvas.Left="0" Canvas.Top="0"/>
                    <Path x:Name="GaugeFill"
                          Stroke="#E2001A"
                          StrokeThickness="8"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Canvas.Left="0" Canvas.Top="0"/>
                    <!-- Charge threshold tick markers (amber, shown when Smart Charge enabled) -->
                    <Path x:Name="GaugeStartTick"
                          Stroke="#D8A657"
                          StrokeThickness="2.5"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Canvas.Left="0" Canvas.Top="0"
                          Visibility="Collapsed"
                          Opacity="0.9"/>
                    <Path x:Name="GaugeStopTick"
                          Stroke="#D8A657"
                          StrokeThickness="2.5"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Canvas.Left="0" Canvas.Top="0"
                          Visibility="Collapsed"
                          Opacity="0.9"/>
                </Canvas>
                <!-- Percentage + a compact status glyph in the centre. The glyph (▲ charging /
                     ● idle / ▼ discharging) replaces the old status word, which was too wide and
                     touched the arc. Colour conveys state and is set in code. -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="-3">
                    <TextBlock x:Name="BatteryPercentText"
                               Text="--"
                               FontSize="23"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock x:Name="StatusGlyph"
                               Text="●"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Grid>

            <!-- Right side stats -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                <StackPanel Spacing="2">
                    <TextBlock Text="POWER"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               CharacterSpacing="100"/>
                    <TextBlock x:Name="PowerSourceText"
                               Text="—"
                               FontSize="13"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Text="RATE"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               CharacterSpacing="100"/>
                    <TextBlock x:Name="PowerRateText"
                               Text="—"
                               FontSize="13"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Text="TIME"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               CharacterSpacing="100"/>
                    <TextBlock x:Name="TimeRemainingText"
                               Text="—"
                               FontSize="13"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Battery history sparkline with a time scale along the bottom -->
        <Border Grid.Row="2"
                Margin="0,0,0,12"
                Height="56"
                CornerRadius="5"
                Background="{ThemeResource ControlFillColorDefaultBrush}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Canvas x:Name="SparklineCanvas" Grid.Row="0"/>
                <!-- Time axis: left = span of the visible history, right = now. -->
                <Grid Grid.Row="1" Margin="7,0,7,3">
                    <TextBlock x:Name="SparklineStartLabel"
                               Text="—"
                               FontSize="11"
                               HorizontalAlignment="Left"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    <TextBlock x:Name="SparklineEndLabel"
                               Text="now"
                               FontSize="11"
                               HorizontalAlignment="Right"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Separator -->
        <Border Grid.Row="3"
                Height="1"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                Margin="0,0,0,12"/>

        <!-- Status badges -->
        <StackPanel Grid.Row="4" Spacing="8">

            <!-- Smart Charge badge -->
            <Border x:Name="SmartChargeBadge"
                    CornerRadius="6"
                    Padding="10,8">
                <StackPanel Spacing="0">
                    <!-- Header row: title + indicator dot -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1">
                            <TextBlock Text="Smart Charge"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock x:Name="SmartChargeDetailText"
                                       Text="—"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                                x:Name="SmartChargeIndicator"
                                Width="8" Height="8"
                                CornerRadius="4"
                                VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Threshold sliders — visible when Smart Charge is capable and enabled.
                         Changes auto-apply (debounced); there is no Apply button.
                         Min/Max/StepFrequency are set in code-behind (ConfigureSliderRanges):
                         assigning RangeBase.Minimum via XAML throws a XamlParseException on this
                         Windows App SDK build. -->
                    <StackPanel x:Name="ThresholdSliders"
                                Spacing="0"
                                Margin="0,6,0,0"
                                Visibility="Collapsed">
                        <!-- Start % -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="34"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Start"
                                       FontSize="11" VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Slider Grid.Column="1" x:Name="StartSlider"
                                    Height="28"
                                    IsThumbToolTipEnabled="False"
                                    ValueChanged="OnStartSliderChanged"/>
                            <TextBlock Grid.Column="2" x:Name="StartValueText"
                                       FontSize="11" VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                        <!-- Stop % -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="34"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Stop"
                                       FontSize="11" VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Slider Grid.Column="1" x:Name="StopSlider"
                                    Height="28"
                                    IsThumbToolTipEnabled="False"
                                    ValueChanged="OnStopSliderChanged"/>
                            <TextBlock Grid.Column="2" x:Name="StopValueText"
                                       FontSize="11" VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                    </StackPanel>

                    <!-- One-shot "charge to 100% once" (travel override). Visible whenever Smart
                         Charge is capable so it can also be cancelled while active. -->
                    <Button x:Name="TravelOverrideButton"
                            Content="⚡  Charge to 100 % once"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            FontSize="11"
                            Padding="8,4"
                            Margin="0,8,0,0"
                            Visibility="Collapsed"
                            Click="OnTravelOverrideButton"/>
                </StackPanel>
            </Border>

            <!-- Smart Standby badge -->
            <Border x:Name="SmartStandbyBadge"
                    CornerRadius="6"
                    Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="1">
                        <TextBlock Text="Smart Standby"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <TextBlock x:Name="SmartStandbyDetailText"
                                   Text="—"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <Border Grid.Column="1"
                            x:Name="SmartStandbyIndicator"
                            Width="8" Height="8"
                            CornerRadius="4"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </StackPanel>

    </Grid>
</Window>
