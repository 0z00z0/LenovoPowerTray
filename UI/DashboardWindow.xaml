<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="LenovoTray.UI.DashboardWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <!-- No fixed Width: the grid fills the window, which is sized in code per monitor DPI. -->
    <Grid Padding="20,16,20,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: Header -->
            <RowDefinition Height="Auto"/>  <!-- 1: Gauge + stats -->
            <RowDefinition Height="Auto"/>  <!-- 2: History sparkline -->
            <RowDefinition Height="Auto"/>  <!-- 3: Separator -->
            <RowDefinition Height="Auto"/>  <!-- 4: Status badges -->
            <RowDefinition Height="Auto"/>  <!-- 5: Settings expander -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Lenovo Power"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                   Margin="0,0,0,14"/>

        <!-- Battery gauge section: gauge left, stats right filling remaining width -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Circular arc gauge -->
            <Grid Grid.Column="0" Width="100" Height="100" Margin="0,0,16,0">
                <!-- Background arc (track) -->
                <Canvas Width="100" Height="100">
                    <Path x:Name="GaugeTrack"
                          Stroke="{ThemeResource ControlStrokeColorDefaultBrush}"
                          StrokeThickness="8"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Canvas.Left="0" Canvas.Top="0"/>
                    <Path x:Name="GaugeFill"
                          Stroke="#E2001A"
                          StrokeThickness="8"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Canvas.Left="0" Canvas.Top="0"/>
                    <!-- Charge threshold tick markers (amber, shown when Smart Charge enabled) -->
                    <Path x:Name="GaugeStartTick"
                          Stroke="#D8A657"
                          StrokeThickness="2.5"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Canvas.Left="0" Canvas.Top="0"
                          Visibility="Collapsed"
                          Opacity="0.9"/>
                    <Path x:Name="GaugeStopTick"
                          Stroke="#D8A657"
                          StrokeThickness="2.5"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"
                          Canvas.Left="0" Canvas.Top="0"
                          Visibility="Collapsed"
                          Opacity="0.9"/>
                </Canvas>
                <!-- Percentage text in center -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="BatteryPercentText"
                               Text="--"
                               FontSize="24"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                    <TextBlock x:Name="ChargeStatusText"
                               Text="Loading"
                               FontSize="10"
                               HorizontalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Grid>

            <!-- Right side stats -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="6">
                <StackPanel Spacing="2">
                    <TextBlock Text="POWER"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               CharacterSpacing="100"/>
                    <TextBlock x:Name="PowerSourceText"
                               Text="—"
                               FontSize="13"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Text="RATE"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               CharacterSpacing="100"/>
                    <TextBlock x:Name="PowerRateText"
                               Text="—"
                               FontSize="13"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
                <StackPanel Spacing="2">
                    <TextBlock Text="TIME"
                               FontSize="10"
                               FontWeight="SemiBold"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                               CharacterSpacing="100"/>
                    <TextBlock x:Name="TimeRemainingText"
                               Text="—"
                               FontSize="13"
                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Battery history sparkline -->
        <Border Grid.Row="2"
                Margin="0,0,0,12"
                Height="44"
                CornerRadius="5"
                Background="{ThemeResource ControlFillColorDefaultBrush}">
            <Canvas x:Name="SparklineCanvas"/>
        </Border>

        <!-- Separator -->
        <Border Grid.Row="3"
                Height="1"
                Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                Margin="0,0,0,12"/>

        <!-- Status badges -->
        <StackPanel Grid.Row="4" Spacing="8">

            <!-- Smart Charge badge -->
            <Border x:Name="SmartChargeBadge"
                    CornerRadius="6"
                    Padding="10,8">
                <StackPanel Spacing="0">
                    <!-- Header row: title + indicator dot -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="1">
                            <TextBlock Text="Smart Charge"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <TextBlock x:Name="SmartChargeDetailText"
                                       Text="—"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </StackPanel>
                        <Border Grid.Column="1"
                                x:Name="SmartChargeIndicator"
                                Width="8" Height="8"
                                CornerRadius="4"
                                VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Threshold sliders — visible when Smart Charge is capable and enabled -->
                    <StackPanel x:Name="ThresholdSliders"
                                Spacing="2"
                                Margin="0,10,0,2"
                                Visibility="Collapsed">
                        <!-- Start % -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="34"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Start"
                                       FontSize="11" VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Slider Grid.Column="1" x:Name="StartSlider"
                                    Minimum="5" Maximum="95" StepFrequency="5"
                                    IsThumbToolTipEnabled="False"
                                    ValueChanged="OnStartSliderChanged"/>
                            <TextBlock Grid.Column="2" x:Name="StartValueText"
                                       FontSize="11" VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                        <!-- Stop % -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="36"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="34"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Stop"
                                       FontSize="11" VerticalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                            <Slider Grid.Column="1" x:Name="StopSlider"
                                    Minimum="10" Maximum="100" StepFrequency="5"
                                    IsThumbToolTipEnabled="False"
                                    ValueChanged="OnStopSliderChanged"/>
                            <TextBlock Grid.Column="2" x:Name="StopValueText"
                                       FontSize="11" VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                        </Grid>
                        <Button x:Name="ApplyThresholdsButton"
                                Content="Apply"
                                HorizontalAlignment="Right"
                                FontSize="11"
                                Padding="12,3"
                                Margin="0,4,0,0"
                                Click="OnApplyThresholds"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Smart Standby badge -->
            <Border x:Name="SmartStandbyBadge"
                    CornerRadius="6"
                    Padding="10,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="1">
                        <TextBlock Text="Smart Standby"
                                   FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <TextBlock x:Name="SmartStandbyDetailText"
                                   Text="—"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <Border Grid.Column="1"
                            x:Name="SmartStandbyIndicator"
                            Width="8" Height="8"
                            CornerRadius="4"
                            VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- Settings expander -->
        <Expander x:Name="SettingsExpander"
                  Grid.Row="5"
                  Header="Settings"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Stretch"
                  Margin="0,10,0,0"
                  SizeChanged="OnSettingsExpanderSizeChanged">
            <StackPanel Spacing="10" Padding="2,6,2,4">

                <!-- Low-battery warning toggle -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Spacing="1" VerticalAlignment="Center">
                        <TextBlock Text="Low battery warning"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="Toast when battery falls below threshold"
                                   FontSize="10"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"/>
                    </StackPanel>
                    <ToggleSwitch Grid.Column="1"
                                  x:Name="LowBatteryToggle"
                                  MinWidth="0"
                                  Toggled="OnLowBatteryToggled"/>
                </Grid>

                <!-- Low-battery % threshold (visible only when toggle is on) -->
                <Grid x:Name="LowBatteryPctRow">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="52"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Warn at"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Slider Grid.Column="1"
                            x:Name="LowBatteryPctSlider"
                            Minimum="5" Maximum="50" StepFrequency="1"
                            IsThumbToolTipEnabled="False"
                            VerticalAlignment="Center"
                            ValueChanged="OnLowBatteryPctChanged"/>
                    <TextBlock Grid.Column="2" x:Name="LowBatteryPctValueText"
                               FontSize="11" VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Grid>

                <!-- Startup delay -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="78"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Startup delay"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <Slider Grid.Column="1"
                            x:Name="StartupDelaySlider"
                            Minimum="0" Maximum="120" StepFrequency="5"
                            IsThumbToolTipEnabled="False"
                            VerticalAlignment="Center"
                            ValueChanged="OnStartupDelayChanged"/>
                    <TextBlock Grid.Column="2" x:Name="StartupDelayValueText"
                               FontSize="11" VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Grid>

                <!-- Numeric icon toggle -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Numeric % tray icon"
                               FontSize="11"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <ToggleSwitch Grid.Column="1"
                                  x:Name="NumericIconToggle"
                                  MinWidth="0"
                                  Toggled="OnNumericIconToggled"/>
                </Grid>

                <!-- Export / Import / open settings file -->
                <StackPanel Orientation="Horizontal" Spacing="14">
                    <HyperlinkButton Content="Export…"
                                     FontSize="11"
                                     Padding="0"
                                     Click="OnExportSettings"/>
                    <HyperlinkButton Content="Import…"
                                     FontSize="11"
                                     Padding="0"
                                     Click="OnImportSettings"/>
                    <HyperlinkButton Content="Open file  ↗"
                                     FontSize="11"
                                     Padding="0"
                                     Click="OnOpenSettingsFile"/>
                </StackPanel>

            </StackPanel>
        </Expander>

    </Grid>
</Window>
